{
    "name": "poesyliang/api",
    "description": "PoesyLiang Blog API (Laravel)",
    "type": "project",
    "require": {
        "php": ">=7.2.5",
        "guzzlehttp/guzzle": "^7.0",
        "laravel/framework": "^7.30",
        "tymon/jwt-auth": "^1.0",
        "darkaonline/l5-swagger": "^7.0",
        "zircote/swagger-php": "^3.2",
        "ramsey/uuid": "^3.9",
        "nesbot/carbon": "^2.0",
        "fruitcake/laravel-cors": "^2.0",
        "spatie/laravel-permission": "^3.18",
        "php-amqplib/php-amqplib": "^3.0",
        "monolog/monolog": "^2.0",
        "vlucas/phpdotenv": "^4.1"
    },
    "require-dev": {},
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "classmap": [
            "database/seeds",
            "database/factories"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php -d error_reporting=8191 artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "disable-tls": true,
        "platform": {
            "php": "7.2.34"
        },
        "audit": {
            "ignore": ["PKSA-y2cr-5h3j-g3ys"]
        }
    },
    "repositories": [
        {"type": "composer", "url": "http://packagist.org", "allow_ssl_downgrade": true}
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}
