{
    "name": "poesyliang/api",
    "description": "PoesyLiang PHP API",
    "type": "project",
    "require": {
        "php": ">=7.2",
        "guzzlehttp/guzzle": "^7.0",
        "symfony/deprecation-contracts": "^2.5"
    },
    "autoload": {
        "classmap": ["src/"],
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "audit": {
            "ignore": ["PKSA-y2cr-5h3j-g3ys"]
        }
    }
}
